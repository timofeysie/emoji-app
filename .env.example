# Required
OPENAI_API_KEY=sk-...

# Optional (defaults shown)
HOST=localhost
PORT=3000

# --- AWS Cognito (protect POST /api/chat) ---
# Create a User Pool + public app client (PKCE) + hosted UI domain; see docs/auth.md
COGNITO_USER_POOL_ID=ap-southeast-2_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Use COGNITO_REGION or AWS_REGION for JWKS / issuer URL
COGNITO_REGION=ap-southeast-2

# Local dev without Cognito: set both to true (ignored in NODE_ENV=production)
DISABLE_AUTH=true
VITE_DISABLE_AUTH=true

# Vite (prefix with VITE_ for client bundle). Set in .env for dev; for Docker
# production builds pass as build-args or use .env.production before npm run build:client
VITE_COGNITO_DOMAIN=https://your-prefix.auth.ap-southeast-2.amazoncognito.com
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional; defaults to "openid email profile"
# VITE_COGNITO_SCOPES=openid email profile
# Optional override for chat endpoint (default /api/chat)
# VITE_CHAT_URL=/api/chat
